<%- include("partials/header") %> 

<header class="gradient">
  <h1>Testimonials</h1>
</header>

<div class="container">
    <div class="frame" data-carousel>
        <!-- <button class="carousel-button prev translate-slides" data-carousel-button="prev">
            <svg width="20" height="20" viewBox="0 0 20 20">
                <path d="M13.5 14.5 9 10l4.5-4.5L12 4l-6 6 6 6 1.5-1.5z"></path>
            </svg>
        </button> -->
        <div class="slideshow translate-slides" >
            <ul class="slides translate-slides" data-slides>
                <% testimonials.forEach((t, index) => { %>
                    <li class="slide translate-slides" <%= index === 0 ? 'data-active' : '' %>>
                        <div class="testimonial">

                            <p class="testimonial-text">
                                “<%= t.snippet %>”
                            </p>

                            <div class="testimonial-meta">
                                <div class="client">
                                    <div class="client-info">
                                        <span class="client-name"><%= t.name %></span>
                                        <span class="client-title"><%= t.title %></span>
                                    </div>
                                    <div class="client-img">
                                        <% const photo = t.photo && t.photo.trim() ? t.photo : 'profile_placeholder.png'; %>
                                        <img src="/img/testimonial_photos/<%= photo %>" alt="<%= t.name %>">
                                    </div>
                                </div>

                                <%const slug = t.slug || t.name.toLowerCase().replace(/\s+/g, '-');%>
                                <a href="/testimonials/<%= slug %>" class = "testimonial-full-text">
                                    <span>Read full testimonial </span>
                                    <svg width="1rem" height="1rem" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M4 12H20M20 12L14 6M20 12L14 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </li>
                <% }) %>
            </ul>
            <!-- <div class="navigation" data-dots>
                <% testimonials.forEach((slide, index) => { %>
                    <div class="circle translate-slides" <%= index === 0 ? 'data-active' : '' %>></div>
                 <% }) %>
            </div> -->
        </div>
        <!-- <button class="carousel-button next translate-slides" data-carousel-button="next">
            <svg width="20" height="20" viewBox="0 0 20 20" viewBox="0 0 20 20">
                <path d="M6.5 5.5 11 10l-4.5 4.5L8 16l6-6-6-6-1.5 1.5z"></path>
            </svg>
        </button> -->
    </div>
</div>

<%- include("partials/footer") %>